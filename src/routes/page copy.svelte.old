<script lang="ts">
    import { onMount } from 'svelte';
    import Button from '$lib/components/Button.svelte';
    import RadioGroup from '$lib/components/RadioGroup.svelte';
    import InputField from '$lib/components/InputField.svelte';
    import TableSection from '$lib/components/TableSection.svelte';
    import TextArea from '$lib/components/TextArea.svelte';
    import type { CharacterSheet } from '$lib/types';

    let formData: CharacterSheet = $state({
        namn: '',
        syssla: '',
        utseende_ansikte: '',
        utseende_kropp: '',
        utseende_klader: '',
        mutation1: '',
        mutation2: '',
        mutation3: '',
        mutation4: '',
        mutation5: '',
        mutationspoang: {
          1: false,
          2: false,
          3: false,
          4: false,
          5: false,
          6: false,
          7: false,
          8: false,
          9: false,
          10: false
        },
        zonrota: {
          1: false,
          2: false,
          3: false,
          4: false,
          5: false,
          6: false,
          7: false,
          8: false,
          9: false,
          10: false
        },
        rustning_txt: '',
        rustning_skyddsvarde: '',
        talanger: [],
        utrustning: [],
        vapen: [],
        relation_relation1: '',
        rp1_close: false,
        relation_relation2: '',
        rp2_close: false,
        relation_relation3: '',
        rp3_close: false,
        relation_relation4: '',
        rp4_close: false,
        hate_relation: '',
        love_relation: '',
        my_dream: '',

        styrka:{
            value: 0,
            radiogrupp: {
              1: false,
              2: false,
              3: false,
              4: false,
              5: false
            }
        },
        kyla:{
            value: 0,
            radiogrupp: {
              1: false,
              2: false,
              3: false,
              4: false,
              5: false

            }
        },
        skarpa:{
            value: 0,
            radiogrupp: {
              1: false,
              2: false,
              3: false,
              4: false,
              5: false
            }
        },
        kansla:{
            value: 0,
            radiogrupp: {
              1: false,
              2: false,
              3: false,
              4: false,
              5: false
            }
        },
        utsvulten: false,
        somnlos: false,
        uttorkad: false,
        nedkyld: false,
        kritiskaskador: {
          1: false,
          2: false,
          3: false,
        },
        kampa_pa: 0,
        ta_krafttag: 0,
        slass: 0,
        smyga: 0,
        fly: 0,
        skjuta: 0,
        speja: 0,
        forsta_sig_pa: 0,
        kanna_zonen: 0,
        genomskada: 0,
        manipulera: 0,
        varda: 0,
        fardighet1: {
          name: '',
          value: 0,
        },
        fardighet2: {
          name: '',
          value: 0,
        },
        erfarenhetspoang: {
          1: false,
          2: false,
          3: false,
          4: false,
          5: false,
          6: false,
          7: false,
          8: false,
          9: false,
          10: false
        },


    });

    // make minimalistic function to load from storage and save to storage but only if browser
    let saveToLocalStorage= (key: string, data: string) => {

        localStorage.setItem(key, data);
    };

    let loadFromLocalStorage = (key: string) => {
        return localStorage.getItem(key);
    };

    
    function saveForm() {
        saveToLocalStorage('rollFormData', JSON.stringify(formData));
        console.log('Formulär sparat', formData);
    }

    function loadForm() {
        let formData = loadFromLocalStorage('rollFormData');
        if (!formData) return;
        const data = JSON.parse(formData);
        if (data) formData = data;
        else console.log('Inga sparade data hittades.');
    }

    function exportForm() {
        const data = loadFromLocalStorage('rollFormData');
        if (!data) {
            alert('Inga sparade data att exportera.');
            return;
        }
        const parsed = JSON.parse(data);
        const filename = parsed.namn?.trim() || 'character';
        const blob = new Blob([JSON.stringify(parsed, null, 2)], { type: 'application/json' });
        const url = URL.createObjectURL(blob);
        const a = document.createElement('a');
        a.href = url;
        a.download = filename + '.json';
        a.click();
        URL.revokeObjectURL(url);
    }

    function importForm(event: Event) {
        if(!(event.target as HTMLInputElement).files || !(event.target as HTMLInputElement).files?.length) return;

        let files = (event.target as HTMLInputElement).files;
        if (!files) return;
        const file = files[0];
        if (!file) return;
        const reader = new FileReader();
        reader.onload = (e) => {
            let result = e.target?.result;
            if (!result) return;
            formData = JSON.parse(result as string);
            saveToLocalStorage('rollFormData', JSON.stringify(formData));
        };
        reader.readAsText(file);
    }

    onMount(() => {
        loadForm();
        setInterval(saveForm, 25000);

    });


</script>

<main class="container">
  <h2>Rollformulär Mutant År: Noll</h2>
  <div class="button-group">
    <Button on:click={saveForm} title="Spara" icon="save" />
    <Button on:click={loadForm} title="Ladda in från cache" icon="load" />
    <Button on:click={exportForm} title="Exportera till fil" icon="export" />
    <input type="file" accept=".json" on:change={importForm} style="display:none;" id="importFile" />
    <Button on:click={() => document?.getElementById('importFile')?.click()} title="Ladda in från fil" icon="import" />
  </div>

  <div class="columns">
    <div class="column left">
      <TableSection title="Grundeegenskaper">
        <InputField bind:bindValue={formData.styrka} label="Styrka" type="number" />
        <RadioGroup name="styrka" options={[formData.styrka, formData.styrka2, formData.styrka3, formData.styrka4, formData.styrka5]} title="Skada"/>
        <InputField bind:bindValue={formData.kyla} label="Kyla" type="number" />
        <RadioGroup name="kyla" options={[1, 2, 3, 4, 5]} title="Stress" bind:bindValue={formData.kyla} />
      </TableSection>

      <TableSection title="Tillstånd">
        <RadioGroup name="utsvulten" options={[1]} title="Utsvulten" bind:bindValue={formData.utsvulten} />
        <RadioGroup name="somnlos" options={[1]} title="Sömnlös" bind:bindValue={formData.somnlos} />
      </TableSection>

      <TableSection title="Färdigheter">
        <InputField bind:value={formData.kampa_pa} label="Kämpa på (STY)" type="number" />
        <InputField bind:value={formData.smyga} label="Smyga (KYL)" type="number" />
      </TableSection>
    </div>

    <div class="column right">
      <TableSection title="Karaktärsinformation">
        <InputField bind:value={formData.namn} label="Namn" type="text" />
        <InputField bind:value={formData.syssla} label="Syssla" type="text" />
      </TableSection>

      <TableSection title="Utseende">
        <TextArea bind:value={formData.ansikte} label="Ansikte" />
        <TextArea bind:value={formData.kropp} label="Kropp" />
      </TableSection>
    </div>
  </div>
</main>
